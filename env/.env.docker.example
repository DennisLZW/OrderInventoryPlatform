# Docker Compose — copy to repo root as `.env.docker` (see README)
# docker compose --env-file .env.docker up --build

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=order_inventory_db
POSTGRES_PORT=5432

# API
API_PORT=8080
ASPNETCORE_ENVIRONMENT=Development
APPLY_MIGRATIONS_ON_STARTUP=true

# CORS (Vite dev server)
CORS_ORIGIN_0=http://localhost:5173
CORS_ORIGIN_1=http://127.0.0.1:5173

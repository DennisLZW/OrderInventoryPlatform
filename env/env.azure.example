# Azure (App Service / Container Apps) — application settings
# Set in Azure Portal → Configuration → Application settings, or in Bicep / pipeline variables.
#
# Azure Database for PostgreSQL Flexible Server + Npgsql:
#   - Host: <server>.postgres.database.azure.com
#   - Port: 5432
#   - SSL REQUIRED — include in connection string:
#       Ssl Mode=Require;Trust Server Certificate=false
#
# Example connection string (replace values; never commit secrets):
# ConnectionStrings__DefaultConnection=Host=myserver.postgres.database.azure.com;Port=5432;Database=order_inventory_db;Username=oipadmin;Password=<SECRET>;Ssl Mode=Require;Trust Server Certificate=false

# ASP.NET Core
# ASPNETCORE_ENVIRONMENT=Production

# Database migrations on startup (optional; prefer managed pipelines in production)
# Database__ApplyMigrationsOnStartup=true

# CORS — frontend origin(s)
# Cors__AllowedOrigins__0=https://your-static-webapp.azurestaticapps.net
# Cors__AllowedOrigins__1=https://your-domain.com

# Optional: force forwarded headers (usually auto-detected on App Service / Container Apps)
# Azure__UseForwardedHeaders=true
